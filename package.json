{
  "name": "midnight-doc-manager",
  "version": "1.0.0",
  "type": "module",
  "description": "Privacy-preserving document management system on Midnight blockchain",
  "author": "",
  "license": "MIT",
  "scripts": {
    "compile": "compact compile contracts/document-manager.compact contracts/managed/document-manager",
    "build": "tsc",
    "setup": "npm run compile && npm run build",
    "local-dev": "cd midnight-local-dev && npm install && npm start",
    "deploy": "tsx src/deploy.ts",
    "generate-dust": "tsx src/generate-dust.ts",
    "cli": "tsx src/cli.ts",
    "check-balance": "tsx src/check-balance.ts",
    "reset": "rm -rf contracts/managed deployment.json dist && npm run compile",
    "clean": "rm -rf dist contracts/managed deployment.json",
    "proof-server": "docker run -p 6300:6300 midnightntwrk/proof-server:7.0.0 midnight-proof-server",
    "preprod": "MIDNIGHT_NETWORK=preprod tsx src/deploy.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.14.0",
    "@midnight-ntwrk/ledger-v7": "7.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "3.0.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-network-id": "3.0.0",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "3.0.0",
    "@midnight-ntwrk/midnight-js-types": "3.0.0",
    "@midnight-ntwrk/midnight-js-utils": "3.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.0.0",
    "@scure/bip39": "^2.0.1",
    "arweave": "^1.15.5",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.3.1",
    "pinata": "^1.6.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rxjs": "^7.8.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "smoldot": "npm:@aspect-build/empty@0.0.0",
    "@midnight-ntwrk/ledger-v7": "7.0.0",
    "@midnight-ntwrk/midnight-js-network-id": "3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "midnight",
    "blockchain",
    "zero-knowledge",
    "privacy",
    "document-management",
    "ipfs",
    "arweave"
  ]
}
