# Midnight Document Manager Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════
# NETWORK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Set to 'undeployed' for local dev or 'preprod' for preprod
MIDNIGHT_NETWORK=undeployed

# Proof server (must be running locally via Docker)
PROOF_SERVER_URL=http://127.0.0.1:6300

# ── Local development (undeployed) ──────────────────────────────────
# These are the default values for midnight-local-dev.
# The proof server is included in the local stack — no separate container needed.
# You only need to set these if your ports differ.
#
# MIDNIGHT_INDEXER_URL=http://127.0.0.1:8088/api/v3/graphql
# MIDNIGHT_INDEXER_WS_URL=ws://127.0.0.1:8088/api/v3/graphql/ws
# MIDNIGHT_NODE_URL=http://127.0.0.1:9944

# ── Preprod ─────────────────────────────────────────────────────────
# When MIDNIGHT_NETWORK=preprod these defaults are used automatically.
# Only override if you need custom endpoints.
#
# MIDNIGHT_INDEXER_URL=https://indexer.preprod.midnight.network/api/v3/graphql
# MIDNIGHT_INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v3/graphql/ws
# MIDNIGHT_NODE_URL=https://rpc.preprod.midnight.network

# ═══════════════════════════════════════════════════════════════════
# STORAGE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# Storage provider: ipfs | arweave
STORAGE_PROVIDER=ipfs

# Password for encrypted private state storage
STORAGE_PASSWORD=your_secure_storage_password_here

# Pinata IPFS Configuration
# Get your JWT at: https://app.pinata.cloud/developers/api-keys
#
# PINATA_GATEWAY must be your dedicated gateway domain from:
# https://app.pinata.cloud/gateway
# It looks like: https://your-name.mypinata.cloud
# Do NOT use https://gateway.pinata.cloud — that is the shared gateway
# and does not support authenticated file retrieval.
PINATA_JWT=your_pinata_jwt_token_here
PINATA_GATEWAY=https://your-dedicated-gateway.mypinata.cloud

# Arweave Configuration (alternative to IPFS)
# Generate wallet at: https://arweave.app
ARWEAVE_WALLET_PATH=./arweave-wallet.json
ARWEAVE_GATEWAY=https://arweave.net

# ═══════════════════════════════════════════════════════════════════
# CONTRACT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

CONTRACT_NAME=document-manager

# Set after running deploy
CONTRACT_ADDRESS=

# ═══════════════════════════════════════════════════════════════════
# DEBUG
# ═══════════════════════════════════════════════════════════════════

DEBUG_LEVEL=info
